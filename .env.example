# =========================================================
# AMI Copiloto Backend - variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# =========================================================

# --- App general ---
APP_ENV=local                     # local | staging | production
APP_DEBUG=true
APP_NAME=ami-copiloto-backend
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Base de datos (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://ami:ami@postgres:5432/ami_copiloto
DATABASE_URL_SYNC=postgresql+psycopg2://ami:ami@postgres:5432/ami_copiloto

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- ChromaDB (vector store para RAG) ---
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION_NORMATIVA=normativa_municipal
RAG_SIMILARITY_THRESHOLD=0.45     # umbral minimo de similitud coseno (calibrado con
                                   # all-MiniLM-L6-v2, ver docs/decisiones-tecnicas.md ADR-006)
RAG_TOP_K=5

# --- Gemini (Google GenAI) ---
# Conseguir una key gratis en https://aistudio.google.com/apikey
# gemini-flash-lite-latest tiene su propio cupo gratuito diario, separado del
# de gemini-flash-latest (que se agota rapido: ~20 requests/dia en la practica).
# Si vas a hacer una demo en vivo, considera habilitar facturacion en el
# proyecto de Google Cloud asociado a la key para levantar el limite diario.
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-flash-lite-latest
# Si GEMINI_MODEL agota su cupo diario (429), el backend reintenta automaticamente
# con este alias (cupo separado) antes de fallar la conversacion.
GEMINI_FALLBACK_MODEL=gemini-flash-latest
GEMINI_MAX_TOKENS=1024

# --- Tavily (busqueda web real, complementa el RAG de normativa) ---
# Conseguir una key gratis (sin tarjeta) en https://tavily.com
# Vacio = la tool buscar_en_internet responde "no configurada" en vez de fallar.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=4

# --- JWT (dashboard admin) ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=true      # false solo para pruebas locales sin firma real
# Generar con: python -m scripts.setup_whatsapp_menu (una sola vez)
TWILIO_MENU_CONTENT_SID=

# --- Rate limiting ---
RATE_LIMIT_MESSAGES_PER_MINUTE=10
RATE_LIMIT_DOCUMENTS_PER_HOUR=20

# --- Integraciones municipales ---
ESITRAM_MODE=mock                 # mock | real
ESITRAM_API_URL=https://esitram.lapaz.bo.example/api
ESITRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ESITRAM_TIMEOUT_SECONDS=8

IGOB_MODE=mock                    # mock | real
IGOB_API_URL=https://igob.lapaz.bo.example/api
IGOB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
IGOB_TIMEOUT_SECONDS=8

GESTION_DOCUMENTAL_MODE=mock
GESTION_DOCUMENTAL_API_URL=https://gestiondocumental.lapaz.bo.example/api
GESTION_DOCUMENTAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Proactividad (workers) ---
PROACTIVE_ENGINE_INTERVAL_MINUTES=30
PROACTIVE_ENGINE_ENABLED=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
